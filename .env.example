# Core
DATABASE_URL=sqlite:///./local.db
# Staging/production (docker compose maps Postgres to host port 5433):
# DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5433/mydb
JWT_SECRET=change-me-in-production
ENV=local

# Web (browser calls API on the host)
NEXT_PUBLIC_API_URL=http://localhost:3001
REACT_APP_API_URL=http://localhost:3001
REACT_APP_WEB_URL=http://localhost:3003

# Worker
REDIS_URL=redis://127.0.0.1:6379
API_URL=http://localhost:3001

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OIDC SSO (Google Workspace)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3001/auth/oidc/callback
OIDC_ISSUER=https://accounts.google.com

# Payments — Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notifications
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# KYC / CRM
DIDIT_CLIENT_ID=
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
TWENTY_API_KEY=
TWENTY_WORKSPACE_URL=

# Government APIs
SEC_USER_AGENT=YourName your@email.com
CONGRESS_API_KEY=
FEC_API_KEY=
REGULATIONS_GOV_API_KEY=
GOVINFO_API_KEY=
SAM_GOV_API_KEY=
COURTLISTENER_API_TOKEN=
OPENCORPORATES_API_KEY=
SANCTIONS_API_KEY=
GLEIF_API_BASE_URL=https://api.gleif.org/api/v1

# Storage / Search
OPENSEARCH_URL=
OPENSEARCH_INDEX=enterprise-docs
S3_ENDPOINT=
S3_BUCKET=enterprise-evidence
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
EVIDENCE_VAULT_DIR=vault

# Optional commercial
MERCADOPAGO_ACCESS_TOKEN=
NFEIO_API_KEY=
FOCUSNFE_API_TOKEN=

# Git (local only — never commit real tokens)
# GITHUB_TOKEN=

# =========================================================================
# Phase 2 — U.S. 50-State Registry + BEA (11 June 2026)
# =========================================================================

# BEA — free signup https://apps.bea.gov/API/signup/
BEA_API_USER_ID=

# California SOS BE API (optional) — https://calicodev.sos.ca.gov/
CA_SOS_API_KEY=

# Cobalt SOS fallback (optional, per-use) — https://cobaltintelligence.stoplight.io
COBALT_API_KEY=

# Registry API (generated keys stored in DB; optional bootstrap admin key)
REGISTRY_API_ADMIN_TOKEN=

# Set to "true" to require API key auth on /registry/* routes (default: open)
REGISTRY_REQUIRE_AUTH=false

# Registry seed limit per state (default 50)
REGISTRY_SEED_LIMIT=50
